generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  role      String   // 'waiter', 'cashier', 'chef', 'boss'
  name      String
  passwordHash String?   // Encrypted PIN/Password
  emoji     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id           String        @id @default(uuid())
  displayId    String        @unique
  type         String        // 'dine-in', 'takeaway'
  tableId      Int?
  customerName String?
  status       String        // ORDER_STATUS: draft | sent | ready | delivered | paid | wasted | cancelled
  total        Float
  version      Int           @default(1)
  discount     Float?
  items        OrderItem[]
  payments     Payment[]
  events       OrderEvent[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  productId String
  name      String
  price     Float
  quantity  Int
  category  String   @default("Hot")
  emoji     String
  status    String   // ORDER_ITEM_STATUS: draft | sent | ready | served | wasted
}

model Payment {
  id      String   @id @default(uuid())
  orderId String
  order   Order    @relation(fields: [orderId], references: [id])
  tableId Int?
  method  String   // 'Cash', 'Kaspi'
  amount  Float
  paidAt  DateTime @default(now())
}

model OrderEvent {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  tableId   Int?
  type      String   // ORDER_EVENT_TYPE: ORDER_SENT | ITEM_READY | ITEM_SERVED | ORDER_PAID | ORDER_CANCELLED | ORDER_WASTED
  details   String
  timestamp DateTime @default(now())
}

model MenuItem {
  id          String   @id @default(uuid())
  name        String
  price       Float
  category    String 
  emoji       String   @default("🍽️")
  is_active   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
